# ══════════════════════════════════════════════════════════════════
# Tec Fazer - Environment Variables Configuration
# ══════════════════════════════════════════════════════════════════
# 
# IMPORTANT: 
# - Copy this file to .env.local for local development
# - Add these variables to Vercel for production
# - Never commit .env.local to git (it's in .gitignore)
#
# ══════════════════════════════════════════════════════════════════

# ── App Configuration ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tecfazer.pt
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Database (Neon.tech PostgreSQL) ───────────────────────────────
# Get from: https://console.neon.tech → Your Project → Connection Details
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_m0jVd7CTfUQB@ep-odd-king-anw9wc35-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── NextAuth (Authentication) ─────────────────────────────────────
# Generate secret: openssl rand -base64 32
# Or use: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your-generated-secret-here
NEXTAUTH_URL=https://tecfazer.pt

# For local development, use:
# NEXTAUTH_URL=http://localhost:3000

# ── Stripe (Payment Processing) ───────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── OpenAI (AI Chat Widget) ───────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# ── Resend (Email Service) ────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Free tier: 3000 emails/month
RESEND_API_KEY=re_your_api_key

# ── Uploadthing (File Upload) ─────────────────────────────────────
# Get from: https://uploadthing.com/dashboard
UPLOADTHING_SECRET=sk_live_your_secret
UPLOADTHING_APP_ID=your_app_id

# ── Twilio (Optional - SMS/WhatsApp) ──────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# ── Admin Configuration ───────────────────────────────────────────
ADMIN_EMAIL=geral@tecfazer.pt
NOTIFICATION_EMAIL=info@tecfazer.pt
CRON_SECRET=your-random-cron-secret

# ── Estimator Configuration ───────────────────────────────────────
NEXT_PUBLIC_ESTIMATOR_CURRENCY=EUR

# ══════════════════════════════════════════════════════════════════
# PRIORITY VARIABLES (Required for basic functionality)
# ══════════════════════════════════════════════════════════════════
# 
# 1. DATABASE_URL - Required for all database operations
# 2. NEXTAUTH_SECRET - Required for authentication to work
# 3. NEXTAUTH_URL - Required for login/logout redirects
#
# Without these 3, the site will not work properly!
# ══════════════════════════════════════════════════════════════════
