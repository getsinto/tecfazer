# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tecfazer.pt
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Database (Neon.tech free PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/tecfazer?sslmode=require

# ── NextAuth (run: openssl rand -base64 32 to generate secret) ───
NEXTAUTH_SECRET=your-32-char-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Stripe (stripe.com → Developers → API Keys) ──────────────────
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── OpenAI (platform.openai.com → API Keys) ──────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ── Resend (resend.com → free 3000 emails per month) ─────────────
RESEND_API_KEY=re_your_api_key

# ── Uploadthing (uploadthing.com → free tier) ────────────────────
UPLOADTHING_SECRET=sk_live_your_secret
UPLOADTHING_APP_ID=your_app_id

# ── Twilio (optional — WhatsApp and SMS alerts) ───────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_EMAIL=geral@tecfazer.pt
NOTIFICATION_EMAIL=info@tecfazer.pt
CRON_SECRET=your-random-cron-secret

# ── Estimator ─────────────────────────────────────────────────────
NEXT_PUBLIC_ESTIMATOR_CURRENCY=EUR
